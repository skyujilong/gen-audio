# gen-audio 环境变量示例
#
# 使用方式：
#   cp .env.example .env.local
#   按需修改 .env.local
#   ./run.sh
#
# run.sh 会在启动 uvicorn 前加载 .env.local；如果没有 .env.local，则使用系统环境变量
# 和 app/config.py 里的默认值。

# === 路径 ===
# 数据根目录：SQLite DB、音频产物、speakers、wetext_cache 等都会放在这里。
# 留空/注释则默认使用 <PROJECT_ROOT>/data。
# DATA_ROOT=./data

# === 并发 ===
# 合成 worker 并发数。CPU 或 CUDA 可用显存低时，程序内部仍可能强制降到 1。
MAX_CONCURRENT_SYNTHESIS=2

# === 文本规范化（TN, Text Normalization） ===
# WeTextProcessing 文本规范化总开关。关闭后 normalize_text 直接返回原文。
TEXT_NORM_ENABLED=true

# FST 编译缓存目录。留空/注释则默认使用 <DATA_ROOT>/wetext_cache。
# TEXT_NORM_CACHE_DIR=./data/wetext_cache

# 是否在规范化时去掉「儿化音」后缀。
TEXT_NORM_REMOVE_ERHUA=false

# === 长文本切分 ===
# 日常目标段长。中文 15-20 字是 ChatTTS 较稳定区间。
TEXT_CHUNK_SOFT_MAX=20

# 硬切兜底上限。仅当一段无标点且超过此值时按字数硬砍。
TEXT_CHUNK_HARD_MAX=35

# 短段阈值。短于此值的段尝试和后一段合并。
TEXT_CHUNK_MIN_CHARS=4

# 段与段之间插入的静音长度（秒）。最后一段后不加。
TEXT_CHUNK_PAUSE_SEC=0.12

# 单段重试次数（不含首次）。默认 2 表示最多尝试 3 次。
TEXT_CHUNK_MAX_RETRIES=2

# 塌缩阈值：|wav| > 1e-5 的样本占比低于此值则视为塌缩。
TEXT_CHUNK_COLLAPSE_RATIO=0.05

# 单 job 最大段数。防止超长文本长期独占 worker。
TEXT_CHUNK_MAX_SEGMENTS=50

# === resemble-enhance ===
# 可选：指定 resemble-enhance 模型权重目录，避免下载到 vendor 目录。
# RESEMBLE_ENHANCE_MODEL_REPO=/path/to/resemble-enhance-models
