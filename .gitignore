# 运行时数据（含 SQLite DB / 音频产出 / speakers / wetext_cache 等）
data/*
!data/.gitkeep

# 前端空目录占位
static/*
!static/.gitkeep
# 跟踪实际的前端代码
!static/index.html
!static/draw.html
!static/favorites.html
!static/synthesize.html
!static/css/
!static/js/

# Python
__pycache__/
*.pyc
*.egg-info/
.venv/
venv/

# ChatTTS 模型文件（首次加载自动下载，约 500MB+）
asset/

# resemble-enhance vendored 包的模型权重（1.5G+，走 .venv 的 pip 包或 env 变量复用）
app/core/vendor/resemble_enhance/model_repo/

# 测试 / 工具
.pytest_cache/
.superpowers/
